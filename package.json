{
  "name": "anixops-control-center-workers",
  "version": "1.0.0",
  "description": "Independent AnixOps Control Center Workers API",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "tail": "wrangler tail",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:devmode": "vitest run test/internal-dev.test.ts",
    "test:visualize": "vitest run test/endpoint-visualizer.test.ts",
    "db:migrate": "wrangler d1 migrations apply anixops-db",
    "db:create": "wrangler d1 migrations create anixops-db",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "hono": "^4.0.0",
    "jose": "^5.2.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240117.0",
    "@types/bcryptjs": "^2.4.6",
    "@vitest/coverage-v8": "^1.2.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0",
    "wrangler": "^4.76.0"
  }
}
